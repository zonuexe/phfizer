includes:
	- phpstan-baseline.neon
parameters:
	level: max
	reportUnmatchedIgnoredErrors: false
	inferPrivatePropertyTypeFromConstructor: true
	treatPhpDocTypesAsCertain: false
	bootstrapFiles:
		- vendor/symplify/easy-coding-standard/vendor/autoload.php
	paths:
		- src/
		- tests/
	excludePaths:
		- tests/Analyzer/data/
