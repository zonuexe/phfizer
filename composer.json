{
    "name": "zonuexe/phfizer",
    "type": "project",
    "description": "Phfizer - PHP File Analyzer",
    "license": "MPL-2.0",
    "autoload": {
        "psr-4": {
            "zonuexe\\Phfizer\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "zonuexe\\Phfizer\\": "tests/"
        }
    },
    "require": {
        "php": ">=8.3",
        "illuminate/container": "^12.19",
        "nikic/php-parser": "^5.5",
        "symfony/console": "^7.0",
        "symfony/finder": "^7.0",
        "symfony/var-dumper": "^7.0"
    },
    "require-dev": {
        "phpstan/phpstan": "^2.1",
        "phpunit/phpunit": "^12.2",
        "symplify/easy-coding-standard": "^12.5"
    },
    "bin": [
        "bin/phfizer",
        "bin/phfizer.php"
    ],
    "config": {
        "sort-packages": true
    }
}
